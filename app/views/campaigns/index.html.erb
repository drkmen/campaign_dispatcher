<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Campaigns</h1>
    <%= link_to "New Campaign", new_campaign_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2 px-4 rounded transition duration-150" %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-md">
    <ul role="list" class="divide-y divide-gray-200">
      <% @campaigns.each do |campaign| %>
        <li>
          <%= link_to campaign, class: "block hover:bg-gray-50 transition duration-150" do %>
            <div class="px-4 py-4 sm:px-6">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-indigo-600 truncate"><%= campaign.title %></p>
                <div class="ml-2 flex-shrink-0 flex">
                  <p class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_badge_class(campaign.status) %>">
                    <%= campaign.status.titleize %>
                  </p>
                </div>
              </div>
              <div class="mt-2 sm:flex sm:justify-between">
                <div class="sm:flex">
                  <p class="flex items-center text-sm text-gray-500">
                    <%= campaign.recipients.count %> recipients
                  </p>
                </div>
                <div class="mt-2 flex items-center text-sm text-gray-500 sm:mt-0">
                  <p>
                    Created on <time datetime="<%= campaign.created_at %>"><%= campaign.created_at.strftime("%B %d, %Y") %></time>
                  </p>
                </div>
              </div>
            </div>
          <% end %>
        </li>
      <% end %>
      <% if @campaigns.empty? %>
        <li class="px-4 py-8 text-center text-gray-500">
          No campaigns found. Create your first one!
        </li>
      <% end %>
    </ul>
  </div>
</div>
