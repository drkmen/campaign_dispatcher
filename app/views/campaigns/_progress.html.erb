<%= turbo_frame_tag "campaign_progress" do %>
  <div class="text-right">
    <div class="flex items-center space-x-2">
      <span class="px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_badge_class(campaign.status) %>">
        <%= campaign.status.titleize %>
      </span>
      <span class="text-sm font-semibold text-gray-700">
        Sent <%= campaign.recipients.sent.count %> of <%= campaign.recipients.count %>
      </span>
    </div>
    <div class="mt-2 w-48 bg-gray-200 rounded-full h-1.5">
      <% percentage = campaign.recipients.count > 0 ? (campaign.recipients.sent.count.to_f / campaign.recipients.count * 100).to_i : 0 %>
      <div class="bg-indigo-600 h-1.5 rounded-full" style="width: <%= "#{percentage}%" %>"></div>
    </div>
  </div>
<% end %>
