<div class="container mx-auto px-4 py-8 max-w-2xl">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">New Campaign</h1>
    <p class="mt-2 text-sm text-gray-600">Create a new outreach campaign by providing a title and a list of recipients.</p>
  </div>

  <%= form_with(model: @campaign, class: "space-y-6") do |f| %>
    <% if @campaign.errors.any? %>
      <div class="bg-red-50 p-4 rounded-md">
        <div class="flex">
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800"><%= pluralize(@campaign.errors.count, "error") %> prohibited this campaign from being saved:</h3>
            <div class="mt-2 text-sm text-red-700">
              <ul role="list" class="list-disc pl-5 space-y-1">
                <% @campaign.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <div class="mt-1">
        <%= f.text_field :title, class: "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md", placeholder: "Summer Promotion 2026" %>
      </div>
    </div>

    <div data-controller="nested-form">
      <template data-nested-form-target="template">
        <%= f.fields_for :recipients, Recipient.new, child_index: "NEW_RECORD" do |recipient_f| %>
          <%= render "recipient_fields", f: recipient_f %>
        <% end %>
      </template>

      <h2 class="text-lg font-medium text-gray-900 mb-4">Recipients</h2>
      
      <div data-nested-form-target="container">
        <%= f.fields_for :recipients do |recipient_f| %>
          <%= render "recipient_fields", f: recipient_f %>
        <% end %>
      </div>

      <button type="button" data-action="click->nested-form#add" class="mt-2 inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        Add Recipient
      </button>
    </div>

    <div class="flex justify-end space-x-3">
      <%= link_to "Cancel", campaigns_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
      <%= f.submit "Create Campaign", class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
    </div>
  <% end %>
</div>
